{
  "name": "champions-lab",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "electron": "electron .",
    "package": "next build && electron-builder --win nsis --x64",
    "package:portable": "next build && electron-builder --win portable --x64",
    "package:verbose": "node scripts/package-verbose.cjs"
  },
  "build": {
    "appId": "xyz.championslab.desktop",
    "productName": "Not exactly Champions Lab",
    "asar": true,
    "files": [
      "electron/**/*",
      "out/**/*",
      "public/icon-512.png",
      "package.json"
    ],
    "extraResources": [],
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "public/icon-512.png",
      "artifactName": "ChampionsLab-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Not exactly Champions Lab",
      "uninstallDisplayName": "Not exactly Champions Lab ${version}",
      "deleteAppDataOnUninstall": false,
      "artifactName": "ChampionsLab-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "ChampionsLab-Portable-${version}.exe"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "pako": "^2.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pako": "^2.0.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "node-html-parser": "^7.1.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
